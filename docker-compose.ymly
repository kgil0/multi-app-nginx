services:
  app1:
    image: nginx
    volumes:
      - ./app1:/usr/share/nginx/html:ro

    healthcheck:
      test: ["CMD", "wget", "-q", "--spider", "http://localhost"]
      interval: 5s
      timeout: 2s
      retries: 2
      start_period: 10s

  app1_2:
    image: nginx
    volumes:
      - ./app1_2:/usr/share/nginx/html:ro

    healthcheck:
      test: ["CMD", "wget", "-q", "--spider", "http://localhost"]
      interval: 5s
      timeout: 5s
      retries: 2
      start_period: 10s

  app2:
    image: nginx
    volumes:
      - ./app2:/usr/share/nginx/html:ro

  nginx:
    image: nginx

    ports:
      - "80:80"
      - "443:443"

    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
      - ./certs:/etc/nginx/certs
      - ./logs:/var/log/nginx

    depends_on:
      - app1
      - app1_2
      - app2
      - goaccess

  goaccess:
    image: allinurl/goaccess

    ports:
      - "7889:7890"

    volumes:
      - ./logs:/var/log/nginx

    command: >
      /var/log/nginx/access.log
      --log-format=COMBINED
      --real-time-html
      --addr=0.0.0.0
      --ws-url=wss://49.12.244.57/ws/
      -o /var/log/nginx/report.html
